{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "JRB Compensation Studio",
  "version": "0.9.0",
  "identifier": "com.jrbxsolutions.compensationstudio",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "JRB Compensation Studio",
        "width": 1280,
        "height": 800,
        "minWidth": 960,
        "minHeight": 650,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "publisher": "JRB XSolutions",
    "shortDescription": "Planification sécurisée des augmentations salariales.",
    "longDescription": "Application locale de préparation, simulation, validation et export sécurisé des campagnes d’augmentation salariale.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:jrb-compensation-studio.db"]
    }
  }
}
